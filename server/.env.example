# Azure Janitor API configuration

# Port the Express API listens on
PORT=4000

# Optional: path to the local SQLite database that backs all reads.
# Defaults to <server working directory>/data/janitor.db. The dashboard is empty
# until the first Refresh, which imports resources from Azure into this file.
# DB_PATH=./data/janitor.db

# Serve realistic fake data with no Azure calls at all.
# The app is fully demoable with this set to true.
MOCK_MODE=false

# Optional: replace the static price map with real figures from the
# Consumption API (requires the Cost Management Reader role).
USE_CONSUMPTION_API=true

# Azure identity. Leave these blank when using `az login`, because
# DefaultAzureCredential falls back to the Azure CLI session.
# Fill them in when using a service principal. Never commit a real .env file.
AZURE_SUBSCRIPTION_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

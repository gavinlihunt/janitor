{
  "name": "azure-janitor-server",
  "version": "0.1.0",
  "private": true,
  "description": "Azure Janitor API - flags idle Azure resources and estimates waste",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@azure/arm-appservice": "^15.0.0",
    "@azure/arm-compute": "^22.1.0",
    "@azure/arm-consumption": "^9.2.0",
    "@azure/arm-cosmosdb": "^16.2.0",
    "@azure/arm-monitor": "^7.0.0",
    "@azure/arm-resources": "^5.2.0",
    "@azure/identity": "^4.4.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.4"
  }
}
